# .gitignore for C++/OpenCV/Object Tracking Project

# Build directories
/build/
/x64/
/Win64/
/Debug/
/Release/
/out/
*.sln
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.o
*.obj
*.so
*.dylib
*.dll
*.exe
*.out

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.env
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/
pip-selfcheck.json
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Data files (large files - exclude or use Git LFS)
/data/output/*      
/data/gt/*
/data/videos/* 
/data/images/*  
/models/*

# But keep empty directories
!data/output/.gitkeep
!data/videos/.gitkeep
!data/images/.gitkeep
!data/gt/.gitkeep
!models/.gitkeep

# Temporary files
*.tmp
*.temp
*.bak
